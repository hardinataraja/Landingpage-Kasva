{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "landingpage-kasva.vercel.app"
        }
      ],
      "status": 301,
      "headers": {
        "Location": "https://kasva.store/$1"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
